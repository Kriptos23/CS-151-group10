<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>


<VBox spacing="10" xmlns:fx="http://javafx.com/fxml"
      fx:controller="cs151.application.controller.ListFlashcardsController"
      prefWidth="900" prefHeight="600"
      alignment="CENTER">


    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>


    <Label text="Flashcards"
           style="-fx-font-size: 26px; -fx-font-weight: bold;" />


    <TableView fx:id="table" prefWidth="800" prefHeight="400">
        <columns>
            <TableColumn fx:id="idCol" text="ID" prefWidth="70"/>
            <TableColumn fx:id="deckIdCol" text="Deck ID" prefWidth="100"/>
            <TableColumn fx:id="frontCol" text="Front" prefWidth="220"/>
            <TableColumn fx:id="backCol" text="Back" prefWidth="220"/>
            <TableColumn fx:id="dateCol" text="Created" prefWidth="180"/>
        </columns>
    </TableView>


    <Button text="Back" onAction="#goBack" />
</VBox>

