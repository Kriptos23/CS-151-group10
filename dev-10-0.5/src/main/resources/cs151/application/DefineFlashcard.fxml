<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>


<VBox spacing="12" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cs151.application.controller.DefineFlashcardController"
      prefWidth="900" prefHeight="600">


    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>


    <Label text="Define Flashcard"
           style="-fx-font-size: 26px; -fx-font-weight: bold;" />


    <ComboBox fx:id="deckComboBox" promptText="Select Deck" maxWidth="300" />
    <TextField fx:id="frontField" promptText="Front Text" maxWidth="300" />
    <TextArea fx:id="backArea" promptText="Back Text" prefRowCount="4" maxWidth="300" />


    <Button text="Save Flashcard" onAction="#handleSaveFlashcard" />
    <Button text="Back" onAction="#goBack" />
</VBox>
