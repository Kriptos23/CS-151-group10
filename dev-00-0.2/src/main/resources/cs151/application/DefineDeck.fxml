<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<?import javafx.scene.control.TextField?>
<VBox spacing="10" alignment="CENTER"
      prefWidth="800" prefHeight="600"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cs151.application.controller.DefineDeckController">

    <Label text="Create New Deck"/>

    <TextField fx:id="nameField" promptText="Deck Name"/>
    <TextField fx:id="descField" promptText="Description"/>

    <Button text="Save Deck"
            onAction="#saveDeck"/>

    <Button text="Back"
            onAction="#goBack"/>

</VBox>