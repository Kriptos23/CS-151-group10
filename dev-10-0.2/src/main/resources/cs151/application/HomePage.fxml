<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="16"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cs151.application.controller.HomeController"
      prefWidth="800" prefHeight="600">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="Flashcards System"
           style="-fx-font-size: 28px; -fx-font-weight: bold;" />

    <Label text="Organize and review your study decks"
           style="-fx-font-size: 14px; -fx-text-fill: #666666;" />

    <Label fx:id="statusLabel"
           text="No decks yet. Create your first deck to get started."
           style="-fx-font-size: 16px; -fx-text-fill: #444444;" />

    <Button text="Create Deck"
            onAction="#goToDefineDeck"
            style="-fx-font-size: 14px; -fx-padding: 10 18 10 18;" />
</VBox>