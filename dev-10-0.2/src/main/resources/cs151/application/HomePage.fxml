<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cs151.application.controller.HomeController"
      prefWidth="900" prefHeight="600">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="Flashcards System"
           style="-fx-font-size: 28px; -fx-font-weight: bold;" />

    <Label fx:id="statusLabel"
           text="No decks yet. Create your first deck to get started."
           style="-fx-font-size: 14px;" />

    <Button text="Define Deck" onAction="#goToDefineDeck" />

    <TableView fx:id="deckTable" prefWidth="700" prefHeight="350">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="80" />
            <TableColumn fx:id="nameColumn" text="Deck Name" prefWidth="250" />
            <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="350" />
        </columns>
    </TableView>
</VBox>