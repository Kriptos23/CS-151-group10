<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cs151.application.controller.DefineDeckController"
      prefWidth="900" prefHeight="600">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="Define Deck"
           style="-fx-font-size: 26px; -fx-font-weight: bold;" />

    <TextField fx:id="nameField"
               promptText="Deck Name"
               maxWidth="300" />

    <TextArea fx:id="descriptionArea"
              promptText="Description (optional)"
              prefRowCount="4"
              maxWidth="300" />

    <Button text="Save Deck" onAction="#saveDeck" />
    <Button text="Back" onAction="#goBack" />
</VBox>